# ── Main ───────────────────────────────────────────────────────────

case "${1:-}" in
  init)       do_init ;;
  new)        do_new "$2" ;;
  start)      do_start ;;
  stop)       do_stop ;;
  status)     do_health "$2" ;;
  health)     do_health "$2" ;;
  -h|--help)  do_help ;;
  "")
    # No args: show status if initialized, otherwise guide to init
    if is_initialized; then
      do_health
    else
      echo -e "${GREEN}四季 Shiki — Dev OS Workspace${NC}"
      echo ""
      echo -e "Welcome! Run ${BOLD}./shiki init${NC} to get started."
      echo ""
      do_help
    fi
    ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    echo ""
    do_help
    exit 1
    ;;
esac
