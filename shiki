#!/bin/bash
# ========================================
# 四季 Shiki — Dev OS Workspace CLI
#
# Ports: DB=5433  Ollama=11435  API=3900  UI=5174
#
# Usage:
#   ./shiki              # show status (or guide to init)
#   ./shiki init         # first-time setup (idempotent)
#   ./shiki init --force # re-init even if already set up
#   ./shiki new <name>   # create a new project
#   ./shiki start        # start all services
#   ./shiki stop         # stop all services
#   ./shiki status       # show services + projects
#   ./shiki health       # detailed health report
#   ./shiki notify setup # configure remote approval (ntfy.sh)
#   ./shiki notify test  # send a test notification
#   ./shiki -h           # help
# ========================================

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

PID_DIR="$SCRIPT_DIR/.pids"
mkdir -p "$PID_DIR"

# Trap for cleanup on interruption or error (BR-13)
_shiki_in_init=0
cleanup() {
  local exit_code=$?
  if [ "$_shiki_in_init" -eq 1 ] && [ $exit_code -ne 0 ]; then
    echo ""
    echo -e "${RED}Interrupted — cleaning up stale PIDs...${NC}"
    for pidfile in "$PID_DIR"/*.pid; do
      [ -f "$pidfile" ] || continue
      local pid
      pid=$(cat "$pidfile")
      if ! kill -0 "$pid" 2>/dev/null; then
        rm -f "$pidfile"
      fi
    done
  fi
}
trap cleanup EXIT

# Colors
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ── Helpers ────────────────────────────────────────────────────────

is_initialized() {
  [ -f .env ] && [ -d projects ]
}

check_prereqs() {
  local missing=()
  command -v docker &>/dev/null || missing+=("docker")
  command -v deno   &>/dev/null || missing+=("deno")
  command -v node   &>/dev/null || missing+=("node")

  [ ${#missing[@]} -eq 0 ] && return 0

  echo -e "${RED}Missing dependencies: ${missing[*]}${NC}"
  echo ""

  if command -v brew &>/dev/null; then
    # macOS / Homebrew
    echo -e "${CYAN}Install with Homebrew:${NC}"
    for dep in "${missing[@]}"; do
      case "$dep" in
        docker) echo "  brew install --cask docker" ;;
        deno)   echo "  brew install deno" ;;
        node)   echo "  brew install node" ;;
      esac
    done
    echo ""
    read -p "Install all now? [Y/n] " answer
    if [[ "$answer" =~ ^[Yy]?$ ]]; then
      for dep in "${missing[@]}"; do
        echo -e "${CYAN}Installing $dep...${NC}"
        case "$dep" in
          docker) brew install --cask docker ;;
          deno)   brew install deno ;;
          node)   brew install node ;;
        esac
      done
      echo ""
      # Re-verify after install
      check_prereqs
      return $?
    fi
  elif command -v apt-get &>/dev/null; then
    # Linux / Debian / Ubuntu
    echo -e "${CYAN}Install with apt + install scripts:${NC}"
    for dep in "${missing[@]}"; do
      case "$dep" in
        docker) echo "  curl -fsSL https://get.docker.com | sh" ;;
        deno)   echo "  curl -fsSL https://deno.land/install.sh | sh" ;;
        node)   echo "  curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash - && sudo apt-get install -y nodejs" ;;
      esac
    done
    echo ""
    read -p "Install all now? [Y/n] " answer
    if [[ "$answer" =~ ^[Yy]?$ ]]; then
      for dep in "${missing[@]}"; do
        echo -e "${CYAN}Installing $dep...${NC}"
        case "$dep" in
          docker) curl -fsSL https://get.docker.com | sh ;;
          deno)   curl -fsSL https://deno.land/install.sh | sh ;;
          node)   curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash - && sudo apt-get install -y nodejs ;;
        esac
      done
      echo ""
      check_prereqs
      return $?
    fi
  else
    # No package manager detected — manual instructions
    echo -e "${CYAN}Install manually:${NC}"
    for dep in "${missing[@]}"; do
      case "$dep" in
        docker) echo "  Docker:  https://docs.docker.com/get-docker/" ;;
        deno)   echo "  Deno:    curl -fsSL https://deno.land/install.sh | sh" ;;
        node)   echo "  Node.js: https://nodejs.org" ;;
      esac
    done
  fi

  echo ""
  echo -e "${YELLOW}Or let Claude handle it:${NC}"
  echo -e "  claude \"install shiki dependencies for me\""
  exit 1
}

is_running() {
  local service="$1"
  local pidfile="$PID_DIR/${service}.pid"
  [ -f "$pidfile" ] || return 1
  local pid
  pid=$(cat "$pidfile")
  # Check PID is alive
  kill -0 "$pid" 2>/dev/null || return 1
  # Cross-check: verify the expected port is held by this PID (BR-05)
  local port=""
  case "$service" in
    backend)  port=3900 ;;
    frontend) port=5174 ;;
  esac
  if [ -n "$port" ]; then
    lsof -ti :"$port" 2>/dev/null | grep -qw "$pid" || return 1
  fi
  return 0
}

kill_port() {
  local port="$1"
  local pids
  pids=$(lsof -ti :"$port" 2>/dev/null || true)
  if [ -n "$pids" ]; then
    echo -e "  ${YELLOW}Killing process(es) on port $port (PID $pids)...${NC}"
    echo "$pids" | xargs kill 2>/dev/null || true
    sleep 1
    # Force-kill survivors
    for p in $pids; do
      kill -0 "$p" 2>/dev/null && kill -9 "$p" 2>/dev/null || true
    done
  fi
}

cleanup_stale_pids() {
  for pidfile in "$PID_DIR"/*.pid; do
    [ -f "$pidfile" ] || continue
    local pid
    pid=$(cat "$pidfile")
    if ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$pidfile"
    fi
  done
}

# ── Help ───────────────────────────────────────────────────────────

do_help() {
  echo -e "${GREEN}四季 Shiki — Dev OS Workspace${NC}"
  echo ""
  echo "Usage: ./shiki <command> [args]"
  echo ""
  echo "Commands:"
  echo "  init [--force]   First-time setup (docker, env, services)"
  echo "                   --force: re-init even if already initialized"
  echo "  new <name>       Create a new project in projects/<name>"
  echo "  start            Start all Shiki services"
  echo "  stop             Stop all Shiki services"
  echo "  status           Show running services and projects"
  echo "  health [--ping]  Detailed health report (--ping for uptime check)"
  echo "  notify setup     Configure remote approval via ntfy.sh"
  echo "  notify test      Send a test notification"
  echo "  notify status    Show notification config"
  echo "  -h, --help       Show this help"
  echo ""
  echo "Getting started:"
  echo "  1. ./shiki init"
  echo "  2. ./shiki new my-app"
  echo "  3. cd projects/my-app && claude"
  echo ""
  echo "Services:"
  echo "  Dashboard:  http://localhost:5174"
  echo "  API:        http://localhost:3900"
  echo "  PostgreSQL: localhost:5433"
  echo "  Ollama:     localhost:11435"
}

# ── Init ───────────────────────────────────────────────────────────

do_init() {
  local force=0
  [[ "${1:-}" == "--force" ]] && force=1

  # BR-04: Guard — already initialized without --force
  if is_initialized && [ "$force" -eq 0 ]; then
    echo -e "${GREEN}✓${NC} Shiki workspace already initialized."
    echo -e "  Use ${BOLD}./shiki start${NC} to start services,"
    echo -e "  or  ${BOLD}./shiki init --force${NC} to re-initialize."
    exit 0
  fi

  # BR-03: Stop running services before re-init
  if is_running backend || is_running frontend || docker compose ps --quiet 2>/dev/null | grep -q .; then
    echo -e "${YELLOW}Services detected — stopping before re-init...${NC}"
    do_stop
    echo ""
  fi

  _shiki_in_init=1

  echo -e "${GREEN}四季 Shiki — First-Time Setup${NC}"
  echo ""

  # Prerequisites
  check_prereqs
  echo -e "${GREEN}✓${NC} Prerequisites OK (docker, deno, node)"

  # Clean stale PIDs (BR-05)
  cleanup_stale_pids

  # .env
  if [ ! -f .env ]; then
    cp .env.example .env
    echo -e "${GREEN}✓${NC} Created .env from .env.example"
    echo -e "  ${DIM}Edit .env to change default passwords before production use${NC}"
  else
    echo -e "${GREEN}✓${NC} .env already exists"
  fi

  # Directories
  mkdir -p projects features backups
  [ ! -f projects/.gitkeep ] && touch projects/.gitkeep
  [ ! -f features/.gitkeep ] && touch features/.gitkeep
  echo -e "${GREEN}✓${NC} Directories ready (projects/, features/, backups/)"

  # Docker services (BR-07: skip already running+healthy containers)
  echo ""
  echo -e "${CYAN}Starting Docker services...${NC}"
  source .env

  local docker_needs_up=()
  for svc in db ollama ntfy; do
    local svc_status
    svc_status=$(docker compose ps --format '{{.Status}}' "$svc" 2>/dev/null || true)
    if echo "$svc_status" | grep -qi "up.*healthy\|up.*running"; then
      echo -e "  ${GREEN}✓${NC} $svc already running"
    else
      docker_needs_up+=("$svc")
    fi
  done
  if [ ${#docker_needs_up[@]} -gt 0 ]; then
    docker compose up -d "${docker_needs_up[@]}"
  fi

  echo -ne "  Waiting for PostgreSQL..."
  for i in $(seq 1 30); do
    if docker compose exec -T db pg_isready -U "${POSTGRES_USER:-shiki}" -d "${POSTGRES_DB:-shiki}" &>/dev/null; then
      echo -e " ${GREEN}ready${NC}"
      break
    fi
    [ $i -eq 30 ] && { echo -e " ${RED}timeout — check: docker compose logs db${NC}"; exit 1; }
    sleep 1
    echo -n "."
  done

  echo -ne "  Waiting for Ollama..."
  for i in $(seq 1 60); do
    if curl -sf http://localhost:11435/api/tags &>/dev/null; then
      echo -e " ${GREEN}ready${NC}"
      break
    fi
    [ $i -eq 60 ] && { echo -e " ${RED}timeout — check: docker compose logs ollama${NC}"; exit 1; }
    sleep 1
    echo -n "."
  done

  # Pull embedding model
  docker compose up -d ollama-init

  # Start backend (BR-01: kill orphan on port 3900, BR-08: absolute path)
  echo ""
  echo -e "${CYAN}Starting Deno backend on port 3900...${NC}"
  kill_port 3900

  export DATABASE_URL="postgres://${POSTGRES_USER:-shiki}:${POSTGRES_PASSWORD}@localhost:5433/${POSTGRES_DB:-shiki}"
  export OLLAMA_URL="http://localhost:11435"
  export EMBED_MODEL="nomic-embed-text"
  export WS_PORT=3900

  deno run --allow-net --allow-env --allow-read "$SCRIPT_DIR/src/backend/src/server.ts" > "$SCRIPT_DIR/.pids/backend.log" 2>&1 &
  BACKEND_PID=$!
  echo "$BACKEND_PID" > "$PID_DIR/backend.pid"

  sleep 2

  if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
    echo -e "${RED}Backend failed to start.${NC}"
    echo -e "  ${DIM}Check logs: $SCRIPT_DIR/.pids/backend.log${NC}"
    exit 1
  fi
  echo -e "${GREEN}✓${NC} Backend running (PID $BACKEND_PID)"

  # Start frontend (BR-02: kill orphan on port 5174, BR-09: absolute CWD)
  echo -e "${CYAN}Starting Vue frontend on port 5174...${NC}"
  kill_port 5174

  if [ ! -d "$SCRIPT_DIR/src/frontend/node_modules" ]; then
    echo -e "  ${DIM}Installing npm dependencies...${NC}"
    npm install --silent --prefix "$SCRIPT_DIR/src/frontend"
  fi
  cd "$SCRIPT_DIR/src/frontend"
  npx vite --port 5174 --host > "$SCRIPT_DIR/.pids/frontend.log" 2>&1 &
  FRONTEND_PID=$!
  echo "$FRONTEND_PID" > "$PID_DIR/frontend.pid"
  cd "$SCRIPT_DIR"

  sleep 2

  if ! kill -0 "$FRONTEND_PID" 2>/dev/null; then
    echo -e "${RED}Frontend failed to start.${NC}"
    echo -e "  ${DIM}Check logs: $SCRIPT_DIR/.pids/frontend.log${NC}"
    exit 1
  fi
  echo -e "${GREEN}✓${NC} Frontend running (PID $FRONTEND_PID)"

  _shiki_in_init=0

  # Welcome
  echo ""
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${GREEN}  四季 Shiki — Dev OS Workspace${NC}"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  echo -e "  Dashboard:  ${CYAN}http://localhost:5174${NC}"
  echo -e "  API:        ${CYAN}http://localhost:3900${NC}"
  echo ""
  echo -e "  Next: ${BOLD}./shiki new <project-name>${NC}"
  echo -e "  Then: ${BOLD}cd projects/<name> && claude${NC}"
  echo ""
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# ── New Project ────────────────────────────────────────────────────

do_new() {
  local name="$1"

  if [ -z "$name" ]; then
    echo -e "${RED}Usage: ./shiki new <project-name>${NC}"
    exit 1
  fi

  local project_dir="projects/$name"

  if [ -d "$project_dir" ]; then
    echo -e "${RED}Project '$name' already exists at $project_dir${NC}"
    exit 1
  fi

  echo -e "${CYAN}Creating project: ${BOLD}$name${NC}"
  echo ""

  # Create project structure
  mkdir -p "$project_dir"
  cd "$project_dir"

  # Git init
  git init --quiet
  echo -e "${GREEN}✓${NC} Git repository initialized"

  # Create project adapter from template
  mkdir -p .claude
  cp "$SCRIPT_DIR/.claude/skills/shiki-process/project-adapter-template.md" .claude/project-adapter.md
  echo -e "${GREEN}✓${NC} Project adapter created (.claude/project-adapter.md)"

  # Create basic structure
  mkdir -p features
  touch features/.gitkeep

  # .gitignore
  cat > .gitignore << 'GITIGNORE'
.DS_Store
node_modules/
dist/
.env
.pids/
GITIGNORE
  echo -e "${GREEN}✓${NC} .gitignore created"

  # README
  cat > README.md << README
# $name

> Created with [Shiki (四季)](https://github.com/Fr0zenSide/shiki)

## Getting Started

\`\`\`bash
cd projects/$name
claude
\`\`\`

## Feature Roadmap

<!-- Features tracked by /md-feature will appear here -->
README
  echo -e "${GREEN}✓${NC} README.md created"

  # Initial commit
  git add -A
  git commit --quiet -m "init: $name project scaffold"
  echo -e "${GREEN}✓${NC} Initial commit created"

  # Register in Shiki DB (if API is running)
  if curl -sf http://localhost:3900/health &>/dev/null; then
    local project_id
    project_id=$(curl -sf -X POST http://localhost:3900/api/projects \
      -H "Content-Type: application/json" \
      -d "{\"name\": \"$name\", \"path\": \"projects/$name\"}" 2>/dev/null | grep -o '"id":"[^"]*"' | cut -d'"' -f4)

    if [ -n "$project_id" ]; then
      echo -e "${GREEN}✓${NC} Registered in Shiki (ID: ${DIM}$project_id${NC})"
    else
      echo -e "${DIM}  Shiki API available but project registration returned no ID${NC}"
    fi
  else
    echo -e "${DIM}  Shiki API not running — project not registered (run ./shiki start first)${NC}"
  fi

  cd "$SCRIPT_DIR"

  echo ""
  echo -e "${GREEN}Project '$name' ready.${NC}"
  echo -e "  ${BOLD}cd projects/$name && claude${NC}"
  echo ""
}

# ── Start ──────────────────────────────────────────────────────────

do_start() {
  if ! is_initialized; then
    echo -e "${YELLOW}Shiki is not initialized. Run: ./shiki init${NC}"
    exit 1
  fi

  echo -e "${GREEN}四季 Shiki — Starting services${NC}"
  echo ""

  check_prereqs
  source .env

  # Clean stale PIDs (BR-05)
  cleanup_stale_pids

  # Docker services (BR-07: skip already running+healthy containers)
  echo -e "${CYAN}Starting Docker services (PostgreSQL + Ollama + ntfy)...${NC}"

  local docker_needs_up=()
  for svc in db ollama ntfy; do
    local svc_status
    svc_status=$(docker compose ps --format '{{.Status}}' "$svc" 2>/dev/null || true)
    if echo "$svc_status" | grep -qi "up.*healthy\|up.*running"; then
      echo -e "  ${GREEN}✓${NC} $svc already running"
    else
      docker_needs_up+=("$svc")
    fi
  done
  if [ ${#docker_needs_up[@]} -gt 0 ]; then
    docker compose up -d "${docker_needs_up[@]}"
  fi

  echo -ne "  Waiting for PostgreSQL..."
  for i in $(seq 1 30); do
    if docker compose exec -T db pg_isready -U "${POSTGRES_USER:-shiki}" -d "${POSTGRES_DB:-shiki}" &>/dev/null; then
      echo -e " ${GREEN}ready${NC}"
      break
    fi
    [ $i -eq 30 ] && { echo -e " ${RED}timeout — check: docker compose logs db${NC}"; exit 1; }
    sleep 1
    echo -n "."
  done

  echo -ne "  Waiting for Ollama..."
  for i in $(seq 1 60); do
    if curl -sf http://localhost:11435/api/tags &>/dev/null; then
      echo -e " ${GREEN}ready${NC}"
      break
    fi
    [ $i -eq 60 ] && { echo -e " ${RED}timeout — check: docker compose logs ollama${NC}"; exit 1; }
    sleep 1
    echo -n "."
  done

  # Pull embedding model in background
  docker compose up -d ollama-init

  # Backend (BR-01: kill orphan on port, BR-08: absolute path)
  if ! is_running backend; then
    echo -e "${CYAN}Starting Deno backend on port 3900...${NC}"
    kill_port 3900

    export DATABASE_URL="postgres://${POSTGRES_USER:-shiki}:${POSTGRES_PASSWORD}@localhost:5433/${POSTGRES_DB:-shiki}"
    export OLLAMA_URL="http://localhost:11435"
    export EMBED_MODEL="nomic-embed-text"
    export WS_PORT=3900

    deno run --allow-net --allow-env --allow-read "$SCRIPT_DIR/src/backend/src/server.ts" > "$SCRIPT_DIR/.pids/backend.log" 2>&1 &
    BACKEND_PID=$!
    echo "$BACKEND_PID" > "$PID_DIR/backend.pid"

    sleep 2

    if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
      echo -e "${RED}Backend failed to start.${NC}"
      echo -e "  ${DIM}Check logs: $SCRIPT_DIR/.pids/backend.log${NC}"
      exit 1
    fi
    echo -e "  ${GREEN}✓${NC} Backend running (PID $BACKEND_PID)"
  else
    echo -e "  ${GREEN}✓${NC} Backend already running (PID $(cat "$PID_DIR/backend.pid"))"
  fi

  # Frontend (BR-02: kill orphan on port, BR-09: absolute CWD)
  if ! is_running frontend; then
    echo -e "${CYAN}Starting Vue frontend on port 5174...${NC}"
    kill_port 5174

    if [ ! -d "$SCRIPT_DIR/src/frontend/node_modules" ]; then
      echo -e "  ${DIM}Installing npm dependencies...${NC}"
      npm install --silent --prefix "$SCRIPT_DIR/src/frontend"
    fi
    cd "$SCRIPT_DIR/src/frontend"
    npx vite --port 5174 --host > "$SCRIPT_DIR/.pids/frontend.log" 2>&1 &
    FRONTEND_PID=$!
    echo "$FRONTEND_PID" > "$PID_DIR/frontend.pid"
    cd "$SCRIPT_DIR"

    sleep 2

    if ! kill -0 "$FRONTEND_PID" 2>/dev/null; then
      echo -e "${RED}Frontend failed to start.${NC}"
      echo -e "  ${DIM}Check logs: $SCRIPT_DIR/.pids/frontend.log${NC}"
      exit 1
    fi
    echo -e "  ${GREEN}✓${NC} Frontend running (PID $FRONTEND_PID)"
  else
    echo -e "  ${GREEN}✓${NC} Frontend already running (PID $(cat "$PID_DIR/frontend.pid"))"
  fi

  # Ready
  echo ""
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${GREEN}  四季 Shiki is running${NC}"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "  Dashboard:  ${CYAN}http://localhost:5174${NC}"
  echo -e "  API:        ${CYAN}http://localhost:3900${NC}"
  echo -e "  WebSocket:  ${CYAN}ws://localhost:3900/ws${NC}"
  echo -e "  Health:     ${CYAN}http://localhost:3900/health${NC}"
  echo -e "  ntfy:       ${CYAN}http://localhost:2586${NC}"
  echo -e "  PostgreSQL: ${DIM}localhost:5433${NC}"
  echo -e "  Ollama:     ${DIM}localhost:11435${NC}"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# ── Stop ───────────────────────────────────────────────────────────

do_stop() {
  echo -e "${YELLOW}Shutting down Shiki...${NC}"

  # Stop Deno backend
  if [ -f "$PID_DIR/backend.pid" ]; then
    PID=$(cat "$PID_DIR/backend.pid")
    if kill -0 "$PID" 2>/dev/null; then
      echo -e "  Stopping backend (PID $PID)..."
      kill "$PID" 2>/dev/null || true
    fi
    rm -f "$PID_DIR/backend.pid"
  fi

  # Stop Vite frontend
  if [ -f "$PID_DIR/frontend.pid" ]; then
    PID=$(cat "$PID_DIR/frontend.pid")
    if kill -0 "$PID" 2>/dev/null; then
      echo -e "  Stopping frontend (PID $PID)..."
      kill "$PID" 2>/dev/null || true
    fi
    rm -f "$PID_DIR/frontend.pid"
  fi

  # Stop Docker services
  if docker compose ps --quiet 2>/dev/null | grep -q .; then
    echo -e "  Stopping Docker services..."
    docker compose down
  fi

  echo -e "${GREEN}Shiki stopped.${NC}"
}

# ── Status ─────────────────────────────────────────────────────────

do_status() {
  echo -e "${GREEN}四季 Shiki — Status${NC}"
  echo ""

  if ! is_initialized; then
    echo -e "${YELLOW}Not initialized.${NC} Run: ${BOLD}./shiki init${NC}"
    echo ""
    return
  fi

  # Docker
  echo -e "${CYAN}Docker services:${NC}"
  if docker compose ps 2>/dev/null | grep -q "running"; then
    docker compose ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null
  else
    echo -e "  ${DIM}not running${NC}"
  fi
  echo ""

  # Backend
  echo -ne "${CYAN}Backend (port 3900):${NC} "
  if is_running backend; then
    echo -e "${GREEN}running${NC} (PID $(cat "$PID_DIR/backend.pid"))"
    if curl -sf http://localhost:3900/health &>/dev/null; then
      echo -e "  ${GREEN}✓${NC} Health check passed"
    fi
  else
    echo -e "${DIM}not running${NC}"
  fi

  # Frontend
  echo -ne "${CYAN}Frontend (port 5174):${NC} "
  if is_running frontend; then
    echo -e "${GREEN}running${NC} (PID $(cat "$PID_DIR/frontend.pid"))"
  else
    echo -e "${DIM}not running${NC}"
  fi

  # Projects
  echo ""
  echo -e "${CYAN}Projects:${NC}"
  if [ -d "projects" ]; then
    local count=0
    for dir in projects/*/; do
      if [ -d "$dir" ] && [ "$(basename "$dir")" != "*" ]; then
        local proj_name=$(basename "$dir")
        local branch=""
        if [ -d "$dir/.git" ]; then
          branch=$(cd "$dir" && git branch --show-current 2>/dev/null)
          branch=" ${DIM}($branch)${NC}"
        fi
        echo -e "  ${GREEN}$proj_name${NC}$branch"
        count=$((count + 1))
      fi
    done
    [ $count -eq 0 ] && echo -e "  ${DIM}none — run: ./shiki new <name>${NC}"
  else
    echo -e "  ${DIM}none — run: ./shiki new <name>${NC}"
  fi

  # Worktrees
  local worktree_count=$(git worktree list 2>/dev/null | wc -l | tr -d ' ')
  if [ "$worktree_count" -gt 1 ]; then
    echo ""
    echo -e "${CYAN}Active worktrees:${NC}"
    git worktree list 2>/dev/null | tail -n +2 | while read -r line; do
      echo -e "  ${DIM}$line${NC}"
    done
  fi

  echo ""
}

# ── Health ─────────────────────────────────────────────────────────

do_health() {
  local api_url="http://localhost:3900"

  # Quick uptime-kuma compatible check (just exit 0/1)
  if [ "${1:-}" = "--ping" ]; then
    curl -sf "$api_url/health" > /dev/null 2>&1 && exit 0 || exit 1
  fi

  echo -e "${GREEN}四季 Shiki — Health Report${NC}"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""

  # Fetch full health from backend
  local health_json
  health_json=$(curl -sf "$api_url/health/full" 2>/dev/null)

  if [ -z "$health_json" ]; then
    echo -e "  ${RED}✗${NC} Backend          ${RED}unreachable${NC} ($api_url)"
    echo ""

    # Check Docker services directly
    echo -e "${CYAN}Docker Services:${NC}"
    if docker compose ps 2>/dev/null | grep -q "running"; then
      docker compose ps --format "  {{.Name}}: {{.Status}}" 2>/dev/null
    else
      echo -e "  ${RED}✗${NC} Docker services not running"
    fi
    echo ""
    echo -e "${YELLOW}Run: ./shiki start${NC}"
    return 1
  fi

  # Parse and display with python3
  python3 << 'PYEOF' - "$health_json"
import sys, json

data = json.loads(sys.argv[1])
G = "\033[0;32m"
R = "\033[0;31m"
C = "\033[0;36m"
D = "\033[2m"
B = "\033[1m"
NC = "\033[0m"

status = data["status"]
version = data["version"]
uptime = data["uptime"]["human"]
ok = status == "ok"

print(f"  Status:    {G if ok else R}{'✓' if ok else '✗'} {status.upper()}{NC}")
print(f"  Version:   {B}{version}{NC}")
print(f"  Uptime:    {uptime}")
print()

# Services
print(f"{C}Services:{NC}")
db = data["services"]["database"]
emb = data["services"]["embeddings"]
print(f"  {G+'✓'+NC if db else R+'✗'+NC} Database       {'connected' if db else 'disconnected'}")
print(f"  {G+'✓'+NC if emb else R+'✗'+NC} Embeddings     {'connected' if emb else 'disconnected'}")
print()

# Knowledge Base
mem = data.get("memory", {})
total = mem.get("total", 0)
embedded = mem.get("withEmbedding", 0)
sources = mem.get("sources", 0)
cats = mem.get("categories", {})
print(f"{C}Knowledge Base:{NC}")
print(f"  Memories:    {B}{total}{NC} ({embedded} embedded)")
print(f"  Sources:     {sources} ingested")
if cats:
    cat_str = ", ".join(f"{k} ({v})" for k, v in sorted(cats.items(), key=lambda x: -x[1])[:6])
    print(f"  Categories:  {D}{cat_str}{NC}")
print()

# Pipelines
pl = data.get("pipelines", {})
if pl.get("total", 0) > 0:
    print(f"{C}Pipelines:{NC}")
    print(f"  Total: {pl['total']}  |  Running: {pl.get('running', 0)}  |  Completed: {pl.get('completed', 0)}  |  Failed: {pl.get('failed', 0)}")
    print()

# Workspace
projects = data.get("projects", 0)
radar = data.get("radar", {}).get("watchedRepos", 0)
print(f"{C}Workspace:{NC}")
print(f"  Projects:    {projects}")
print(f"  Radar:       {radar} repos watched")
print()

# Agents
print(f"{C}Agent Team ({len(data.get('agents', []))} personas):{NC}")
for a in data.get("agents", []):
    print(f"  {G}{a['handle']:12}{NC} {D}({a['alias']}){NC}  {a['role']}")
print()

# Commands
cmds = data.get("commands", [])
print(f"{C}Commands ({len(cmds)} available):{NC}")
for c in cmds:
    print(f"  {B}{c['name']:20}{NC} {c['desc']}")

PYEOF

  echo ""
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "  API:    ${CYAN}http://localhost:3900${NC}"
  echo -e "  Health: ${CYAN}http://localhost:3900/health/full${NC}"
  echo -e "  Ping:   ${DIM}./shiki health --ping${NC} (uptime-kuma)"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# ── Notify ─────────────────────────────────────────────────────

do_notify() {
  local subcmd="${1:-}"
  local CONFIG_DIR="$HOME/.config/shiki-notify"
  local CONFIG_FILE="$CONFIG_DIR/config"
  local HOOK_SCRIPT="$SCRIPT_DIR/scripts/shiki-approval.sh"

  case "$subcmd" in
    setup)
      echo -e "${GREEN}四季 Shiki — Remote Approval Setup${NC}"
      echo ""
      echo "This configures push notifications for Claude Code permission requests."
      echo "When Claude needs approval, you'll get a notification on your phone/watch"
      echo "with [Approve] [Always Allow] [Deny] buttons."
      echo ""
      echo -e "${CYAN}Prerequisites:${NC}"
      echo "  1. Install ntfy app on iPhone: https://apps.apple.com/app/ntfy/id1625396347"
      echo "  2. Shiki embeds its own ntfy server at http://localhost:2586"
      echo "     (started automatically with ./shiki start)"
      echo ""

      # Check if ntfy container is running
      if docker compose ps ntfy 2>/dev/null | grep -q "running"; then
        echo -e "  ${GREEN}✓${NC} ntfy server is running (port 2586)"
      else
        echo -e "  ${YELLOW}!${NC} ntfy server not running. Starting it..."
        docker compose up -d ntfy
        sleep 2
        if docker compose ps ntfy 2>/dev/null | grep -q "running"; then
          echo -e "  ${GREEN}✓${NC} ntfy server started"
        else
          echo -e "  ${RED}✗${NC} Failed to start ntfy. Check: docker compose logs ntfy"
        fi
      fi
      echo ""

      # Get topic
      local default_topic="shiki-$(whoami)"
      read -p "ntfy topic name [$default_topic]: " topic
      topic="${topic:-$default_topic}"

      # Server: default to embedded
      echo ""
      echo "  Shiki includes a local ntfy server (recommended)."
      echo "  Use https://ntfy.sh for public cloud, or your own server."
      read -p "ntfy server [http://localhost:2586]: " server
      server="${server:-http://localhost:2586}"

      # For iPhone: need to expose or use upstream
      if [[ "$server" == *"localhost"* ]]; then
        echo ""
        echo -e "${YELLOW}Note:${NC} For iPhone/Apple Watch notifications, you need your"
        echo "  phone to reach this server. Options:"
        echo ""
        echo "  ${BOLD}a)${NC} Use Tailscale/WireGuard (recommended) — your Mac gets a"
        echo "     stable IP like 100.x.x.x, set server to http://100.x.x.x:2586"
        echo ""
        echo "  ${BOLD}b)${NC} Use ntfy.sh cloud — set server to https://ntfy.sh"
        echo "     (free, public topics — use a unique random topic name)"
        echo ""
        echo "  ${BOLD}c)${NC} Use upstream relay — local ntfy forwards to ntfy.sh"
        echo "     (configure in ntfy server config later)"
        echo ""
        read -p "Change server? (enter new URL or press Enter to keep local): " alt_server
        if [ -n "$alt_server" ]; then
          server="$alt_server"
        fi
      fi

      # Optional: access token
      read -p "ntfy access token (leave empty for public topics): " token

      # Optional: timeout
      read -p "Approval timeout in seconds [120]: " timeout
      timeout="${timeout:-120}"

      # Optional: auto-approve tools
      echo ""
      echo -e "${CYAN}Auto-approve (skip notification for safe tools):${NC}"
      echo "  Common safe tools: Read, Glob, Grep, Bash(read-only)"
      echo "  Leave empty to get notified for everything."
      read -p "Auto-approve tools (comma-separated): " auto_approve

      # Write config
      mkdir -p "$CONFIG_DIR"
      cat > "$CONFIG_FILE" << CONF
# Shiki Remote Approval Configuration
# Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)

NTFY_TOPIC="$topic"
NTFY_SERVER="$server"
NTFY_TOKEN="$token"
NTFY_TIMEOUT="$timeout"
AUTO_APPROVE_TOOLS="$auto_approve"
CONF
      chmod 600 "$CONFIG_FILE"
      echo ""
      echo -e "${GREEN}✓${NC} Config saved to $CONFIG_FILE"

      echo ""
      echo -e "${YELLOW}IMPORTANT: In the ntfy app, subscribe ONLY to:${NC}"
      echo -e "  ${BOLD}$topic${NC}"
      echo ""
      echo -e "  ${DIM}Do NOT subscribe to ${topic}-response — that's the${NC}"
      echo -e "  ${DIM}internal callback topic handled by the script.${NC}"

      # Install Claude Code hook
      echo ""
      echo -e "${CYAN}Installing Claude Code hook...${NC}"

      # Check for existing settings files
      local settings_file="$HOME/.claude/settings.json"
      local local_settings="$SCRIPT_DIR/.claude/settings.local.json"

      # We'll use the project-level settings.local.json
      if [ -f "$local_settings" ]; then
        # Merge hook into existing settings
        python3 << PYEOF
import json

hook_script = "$HOOK_SCRIPT"
settings_path = "$local_settings"

with open(settings_path, 'r') as f:
    settings = json.load(f)

# Add or update hooks
if 'hooks' not in settings:
    settings['hooks'] = {}

settings['hooks']['PermissionRequest'] = [
    {
        "matcher": "",
        "hooks": [
            {
                "type": "command",
                "command": hook_script,
                "timeout": $timeout
            }
        ]
    }
]

with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')

print("Updated existing settings.local.json")
PYEOF
      else
        # Create new settings.local.json
        python3 << PYEOF
import json

hook_script = "$HOOK_SCRIPT"
settings_path = "$local_settings"

settings = {
    "hooks": {
        "PermissionRequest": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": hook_script,
                        "timeout": $timeout
                    }
                ]
            }
        ]
    }
}

with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')

print("Created settings.local.json")
PYEOF
      fi

      echo -e "${GREEN}✓${NC} Claude Code hook installed"
      echo ""
      echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
      echo -e "${GREEN}  Remote approval is ready!${NC}"
      echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
      echo ""
      echo "  Next time Claude Code asks for permission, you'll get a"
      echo "  push notification with approve/deny buttons."
      echo ""
      echo -e "  Test it: ${BOLD}./shiki notify test${NC}"
      echo ""
      ;;

    test)
      if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}Not configured. Run: ./shiki notify setup${NC}"
        exit 1
      fi

      source "$CONFIG_FILE"

      echo -e "${CYAN}Sending test notification to ${BOLD}$NTFY_TOPIC${NC}..."

      local auth_args=()
      if [ -n "${NTFY_TOKEN:-}" ]; then
        auth_args+=(-H "Authorization: Bearer $NTFY_TOKEN")
      fi

      local response_topic="${NTFY_TOPIC}-response"
      local test_id="test-$(date +%s)"

      curl -sf -X POST "$NTFY_SERVER" \
        -H "Content-Type: application/json" \
        "${auth_args[@]}" \
        -d "{
          \"topic\": \"$NTFY_TOPIC\",
          \"title\": \"Shiki: Test Notification\",
          \"message\": \"Tool: Bash\\nCommand: echo hello world\",
          \"tags\": [\"key\", \"test_tube\"],
          \"priority\": 4,
          \"actions\": [
            {\"action\": \"http\", \"label\": \"Approve\", \"url\": \"$NTFY_SERVER/$response_topic\", \"method\": \"POST\", \"body\": \"approve\", \"clear\": true},
            {\"action\": \"http\", \"label\": \"Deny\", \"url\": \"$NTFY_SERVER/$response_topic\", \"method\": \"POST\", \"body\": \"deny\", \"clear\": true}
          ]
        }" > /dev/null

      echo -e "${GREEN}✓${NC} Test notification sent!"
      echo ""
      echo "  Check your phone/watch for the notification."
      echo "  Tap a button to verify the action works."
      echo ""
      echo -e "  ${DIM}Listening for response (${NTFY_TIMEOUT}s timeout)...${NC}"

      # Listen for response via python3 (reliable SSE + timeout)
      local since_ts
      since_ts=$(date +%s)
      local resp
      resp=$(python3 << PYEOF
import urllib.request, json, sys, time

url = "${NTFY_SERVER}/${response_topic}/json?since=${since_ts}"
req = urllib.request.Request(url)
timeout = int("${NTFY_TIMEOUT:-120}")

try:
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        start = time.time()
        while time.time() - start < timeout:
            line = resp.readline().decode("utf-8").strip()
            if not line:
                continue
            try:
                data = json.loads(line)
                if data.get("event") != "message":
                    continue
                msg = data.get("message", "").strip().lower()
                if msg in ("approve", "deny", "always_allow"):
                    print(msg)
                    sys.exit(0)
            except json.JSONDecodeError:
                continue
except Exception:
    pass
print("")
PYEOF
)

      if [ -n "$resp" ]; then
        echo -e "  ${GREEN}✓${NC} Response received: ${BOLD}$resp${NC}"
      else
        echo -e "  ${YELLOW}No response received (timeout).${NC}"
        echo "  Make sure you subscribed to ${BOLD}$NTFY_TOPIC${NC} in the ntfy app."
      fi
      ;;

    status)
      if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${YELLOW}Not configured.${NC} Run: ${BOLD}./shiki notify setup${NC}"
        return
      fi

      source "$CONFIG_FILE"

      echo -e "${GREEN}四季 Shiki — Notification Status${NC}"
      echo ""
      echo -e "  Server:      ${BOLD}${NTFY_SERVER}${NC}"
      echo -e "  Topic:       ${BOLD}${NTFY_TOPIC}${NC}"
      echo -e "  Response:    ${BOLD}${NTFY_TOPIC}-response${NC}"
      echo -e "  Timeout:     ${NTFY_TIMEOUT}s"
      echo -e "  Auth:        ${NTFY_TOKEN:+configured}${NTFY_TOKEN:-none}"
      echo -e "  Auto-approve: ${AUTO_APPROVE_TOOLS:-none}"
      echo ""

      # Check hook installation
      local local_settings="$SCRIPT_DIR/.claude/settings.local.json"
      if [ -f "$local_settings" ] && grep -q "shiki-approval" "$local_settings" 2>/dev/null; then
        echo -e "  Hook:        ${GREEN}✓${NC} installed in settings.local.json"
      else
        echo -e "  Hook:        ${RED}✗${NC} not installed (run ./shiki notify setup)"
      fi

      # Check log
      local LOG_FILE="$CONFIG_DIR/approval.log"
      if [ -f "$LOG_FILE" ]; then
        local log_count=$(wc -l < "$LOG_FILE" | tr -d ' ')
        echo -e "  Log:         $log_count entries ($LOG_FILE)"
        echo ""
        echo -e "${CYAN}Recent approvals:${NC}"
        tail -5 "$LOG_FILE" | while IFS='|' read -r ts decision tool detail; do
          echo -e "  ${DIM}$ts${NC} $decision $tool"
        done
      fi
      ;;

    *)
      echo -e "${YELLOW}Usage:${NC}"
      echo "  ./shiki notify setup    Configure remote approval"
      echo "  ./shiki notify test     Send test notification"
      echo "  ./shiki notify status   Show config and recent approvals"
      ;;
  esac
}

# ── Main ───────────────────────────────────────────────────────────

case "${1:-}" in
  init)       do_init "${2:-}" ;;
  new)        do_new "$2" ;;
  start)      do_start ;;
  stop)       do_stop ;;
  status)     do_status ;;
  health)     do_health "${2:-}" ;;
  notify)     do_notify "${2:-}" ;;
  -h|--help)  do_help ;;
  "")
    # No args: show status if initialized, otherwise guide to init
    if is_initialized; then
      do_health
    else
      echo -e "${GREEN}四季 Shiki — Dev OS Workspace${NC}"
      echo ""
      echo -e "Welcome! Run ${BOLD}./shiki init${NC} to get started."
      echo ""
      do_help
    fi
    ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    echo ""
    do_help
    exit 1
    ;;
esac
