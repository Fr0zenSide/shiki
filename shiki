#!/bin/bash
# ========================================
# 四季 Shiki — Dev OS Workspace CLI
#
# Ports: DB=5433  Ollama=11435  API=3900  UI=5174
#
# Usage:
#   ./shiki              # show status (or guide to init)
#   ./shiki init         # first-time setup
#   ./shiki new <name>   # create a new project
#   ./shiki start        # start all services
#   ./shiki stop         # stop all services
#   ./shiki status       # show services + projects
#   ./shiki -h           # help
# ========================================

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

PID_DIR="$SCRIPT_DIR/.pids"
mkdir -p "$PID_DIR"

# Colors
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ── Helpers ────────────────────────────────────────────────────────

is_initialized() {
  [ -f .env ] && [ -d projects ]
}

check_prereqs() {
  local missing=0

  if ! command -v docker &> /dev/null; then
    echo -e "${RED}Docker not found.${NC} Install: https://docs.docker.com/get-docker/"
    missing=1
  fi

  if ! command -v deno &> /dev/null; then
    echo -e "${RED}Deno not found.${NC} Install: brew install deno"
    missing=1
  fi

  if ! command -v node &> /dev/null; then
    echo -e "${RED}Node.js not found.${NC} Install: https://nodejs.org"
    missing=1
  fi

  [ $missing -eq 1 ] && exit 1
}

is_running() {
  local service="$1"
  [ -f "$PID_DIR/${service}.pid" ] && kill -0 "$(cat "$PID_DIR/${service}.pid")" 2>/dev/null
}

# ── Help ───────────────────────────────────────────────────────────

do_help() {
  echo -e "${GREEN}四季 Shiki — Dev OS Workspace${NC}"
  echo ""
  echo "Usage: ./shiki <command> [args]"
  echo ""
  echo "Commands:"
  echo "  init             First-time setup (docker, env, services)"
  echo "  new <name>       Create a new project in projects/<name>"
  echo "  start            Start all Shiki services"
  echo "  stop             Stop all Shiki services"
  echo "  status           Show running services and projects"
  echo "  -h, --help       Show this help"
  echo ""
  echo "Getting started:"
  echo "  1. ./shiki init"
  echo "  2. ./shiki new my-app"
  echo "  3. cd projects/my-app && claude"
  echo ""
  echo "Services:"
  echo "  Dashboard:  http://localhost:5174"
  echo "  API:        http://localhost:3900"
  echo "  PostgreSQL: localhost:5433"
  echo "  Ollama:     localhost:11435"
}

# ── Init ───────────────────────────────────────────────────────────

do_init() {
  echo -e "${GREEN}四季 Shiki — First-Time Setup${NC}"
  echo ""

  # Prerequisites
  check_prereqs
  echo -e "${GREEN}✓${NC} Prerequisites OK (docker, deno, node)"

  # .env
  if [ ! -f .env ]; then
    cp .env.example .env
    echo -e "${GREEN}✓${NC} Created .env from .env.example"
    echo -e "  ${DIM}Edit .env to change default passwords before production use${NC}"
  else
    echo -e "${GREEN}✓${NC} .env already exists"
  fi

  # Directories
  mkdir -p projects features backups
  [ ! -f projects/.gitkeep ] && touch projects/.gitkeep
  [ ! -f features/.gitkeep ] && touch features/.gitkeep
  echo -e "${GREEN}✓${NC} Directories ready (projects/, features/, backups/)"

  # Docker services
  echo ""
  echo -e "${CYAN}Starting Docker services...${NC}"
  source .env
  docker compose up -d db ollama

  echo -ne "  Waiting for PostgreSQL..."
  for i in $(seq 1 30); do
    if docker compose exec -T db pg_isready -U "${POSTGRES_USER:-shiki}" -d "${POSTGRES_DB:-shiki}" &>/dev/null; then
      echo -e " ${GREEN}ready${NC}"
      break
    fi
    [ $i -eq 30 ] && { echo -e " ${RED}timeout${NC}"; exit 1; }
    sleep 1
    echo -n "."
  done

  echo -ne "  Waiting for Ollama..."
  for i in $(seq 1 60); do
    if curl -sf http://localhost:11435/api/tags &>/dev/null; then
      echo -e " ${GREEN}ready${NC}"
      break
    fi
    [ $i -eq 60 ] && { echo -e " ${RED}timeout${NC}"; exit 1; }
    sleep 1
    echo -n "."
  done

  # Pull embedding model
  docker compose up -d ollama-init

  # Start backend
  echo ""
  echo -e "${CYAN}Starting Deno backend on port 3900...${NC}"

  export DATABASE_URL="postgres://${POSTGRES_USER:-shiki}:${POSTGRES_PASSWORD}@localhost:5433/${POSTGRES_DB:-shiki}"
  export OLLAMA_URL="http://localhost:11435"
  export EMBED_MODEL="nomic-embed-text"
  export WS_PORT=3900

  cd src/backend
  deno run --allow-net --allow-env --allow-read src/server.ts > "$SCRIPT_DIR/.pids/backend.log" 2>&1 &
  BACKEND_PID=$!
  echo "$BACKEND_PID" > "$PID_DIR/backend.pid"
  cd "$SCRIPT_DIR"

  sleep 2

  if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
    echo -e "${RED}Backend failed to start. Check .pids/backend.log${NC}"
    exit 1
  fi
  echo -e "${GREEN}✓${NC} Backend running (PID $BACKEND_PID)"

  # Start frontend
  echo -e "${CYAN}Starting Vue frontend on port 5174...${NC}"

  cd src/frontend
  if [ ! -d "node_modules" ]; then
    echo -e "  ${DIM}Installing npm dependencies...${NC}"
    npm install --silent
  fi
  npx vite --port 5174 --host > "$SCRIPT_DIR/.pids/frontend.log" 2>&1 &
  FRONTEND_PID=$!
  echo "$FRONTEND_PID" > "$PID_DIR/frontend.pid"
  cd "$SCRIPT_DIR"

  sleep 2
  echo -e "${GREEN}✓${NC} Frontend running (PID $FRONTEND_PID)"

  # Welcome
  echo ""
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${GREEN}  四季 Shiki — Dev OS Workspace${NC}"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  echo -e "  Dashboard:  ${CYAN}http://localhost:5174${NC}"
  echo -e "  API:        ${CYAN}http://localhost:3900${NC}"
  echo ""
  echo -e "  Next: ${BOLD}./shiki new <project-name>${NC}"
  echo -e "  Then: ${BOLD}cd projects/<name> && claude${NC}"
  echo ""
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# ── New Project ────────────────────────────────────────────────────

do_new() {
  local name="$1"

  if [ -z "$name" ]; then
    echo -e "${RED}Usage: ./shiki new <project-name>${NC}"
    exit 1
  fi

  local project_dir="projects/$name"

  if [ -d "$project_dir" ]; then
    echo -e "${RED}Project '$name' already exists at $project_dir${NC}"
    exit 1
  fi

  echo -e "${CYAN}Creating project: ${BOLD}$name${NC}"
  echo ""

  # Create project structure
  mkdir -p "$project_dir"
  cd "$project_dir"

  # Git init
  git init --quiet
  echo -e "${GREEN}✓${NC} Git repository initialized"

  # Create project adapter from template
  mkdir -p .claude
  cp "$SCRIPT_DIR/.claude/skills/shiki-process/project-adapter-template.md" .claude/project-adapter.md
  echo -e "${GREEN}✓${NC} Project adapter created (.claude/project-adapter.md)"

  # Create basic structure
  mkdir -p features
  touch features/.gitkeep

  # .gitignore
  cat > .gitignore << 'GITIGNORE'
.DS_Store
node_modules/
dist/
.env
.pids/
GITIGNORE
  echo -e "${GREEN}✓${NC} .gitignore created"

  # README
  cat > README.md << README
# $name

> Created with [Shiki (四季)](https://github.com/Fr0zenSide/shiki)

## Getting Started

\`\`\`bash
cd projects/$name
claude
\`\`\`

## Feature Roadmap

<!-- Features tracked by /md-feature will appear here -->
README
  echo -e "${GREEN}✓${NC} README.md created"

  # Initial commit
  git add -A
  git commit --quiet -m "init: $name project scaffold"
  echo -e "${GREEN}✓${NC} Initial commit created"

  # Register in Shiki DB (if API is running)
  if curl -sf http://localhost:3900/health &>/dev/null; then
    local project_id
    project_id=$(curl -sf -X POST http://localhost:3900/api/projects \
      -H "Content-Type: application/json" \
      -d "{\"name\": \"$name\", \"path\": \"projects/$name\"}" 2>/dev/null | grep -o '"id":"[^"]*"' | cut -d'"' -f4)

    if [ -n "$project_id" ]; then
      echo -e "${GREEN}✓${NC} Registered in Shiki (ID: ${DIM}$project_id${NC})"
    else
      echo -e "${DIM}  Shiki API available but project registration returned no ID${NC}"
    fi
  else
    echo -e "${DIM}  Shiki API not running — project not registered (run ./shiki start first)${NC}"
  fi

  cd "$SCRIPT_DIR"

  echo ""
  echo -e "${GREEN}Project '$name' ready.${NC}"
  echo -e "  ${BOLD}cd projects/$name && claude${NC}"
  echo ""
}

# ── Start ──────────────────────────────────────────────────────────

do_start() {
  if ! is_initialized; then
    echo -e "${YELLOW}Shiki is not initialized. Run: ./shiki init${NC}"
    exit 1
  fi

  echo -e "${GREEN}四季 Shiki — Starting services${NC}"
  echo ""

  check_prereqs
  source .env

  # Docker services
  echo -e "${CYAN}Starting Docker services (PostgreSQL + Ollama)...${NC}"
  docker compose up -d db ollama

  echo -ne "  Waiting for PostgreSQL..."
  for i in $(seq 1 30); do
    if docker compose exec -T db pg_isready -U "${POSTGRES_USER:-shiki}" -d "${POSTGRES_DB:-shiki}" &>/dev/null; then
      echo -e " ${GREEN}ready${NC}"
      break
    fi
    [ $i -eq 30 ] && { echo -e " ${RED}timeout${NC}"; exit 1; }
    sleep 1
    echo -n "."
  done

  echo -ne "  Waiting for Ollama..."
  for i in $(seq 1 60); do
    if curl -sf http://localhost:11435/api/tags &>/dev/null; then
      echo -e " ${GREEN}ready${NC}"
      break
    fi
    [ $i -eq 60 ] && { echo -e " ${RED}timeout${NC}"; exit 1; }
    sleep 1
    echo -n "."
  done

  # Pull embedding model in background
  docker compose up -d ollama-init

  # Backend
  if ! is_running backend; then
    echo -e "${CYAN}Starting Deno backend on port 3900...${NC}"

    export DATABASE_URL="postgres://${POSTGRES_USER:-shiki}:${POSTGRES_PASSWORD}@localhost:5433/${POSTGRES_DB:-shiki}"
    export OLLAMA_URL="http://localhost:11435"
    export EMBED_MODEL="nomic-embed-text"
    export WS_PORT=3900

    cd src/backend
    deno run --allow-net --allow-env --allow-read src/server.ts > "$SCRIPT_DIR/.pids/backend.log" 2>&1 &
    BACKEND_PID=$!
    echo "$BACKEND_PID" > "$PID_DIR/backend.pid"
    cd "$SCRIPT_DIR"

    sleep 2

    if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
      echo -e "${RED}Backend failed to start. Check .pids/backend.log${NC}"
      exit 1
    fi
    echo -e "  ${GREEN}✓${NC} Backend running (PID $BACKEND_PID)"
  else
    echo -e "  ${GREEN}✓${NC} Backend already running (PID $(cat "$PID_DIR/backend.pid"))"
  fi

  # Frontend
  if ! is_running frontend; then
    echo -e "${CYAN}Starting Vue frontend on port 5174...${NC}"

    cd src/frontend
    if [ ! -d "node_modules" ]; then
      echo -e "  ${DIM}Installing npm dependencies...${NC}"
      npm install --silent
    fi
    npx vite --port 5174 --host > "$SCRIPT_DIR/.pids/frontend.log" 2>&1 &
    FRONTEND_PID=$!
    echo "$FRONTEND_PID" > "$PID_DIR/frontend.pid"
    cd "$SCRIPT_DIR"

    sleep 2
    echo -e "  ${GREEN}✓${NC} Frontend running (PID $FRONTEND_PID)"
  else
    echo -e "  ${GREEN}✓${NC} Frontend already running (PID $(cat "$PID_DIR/frontend.pid"))"
  fi

  # Ready
  echo ""
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${GREEN}  四季 Shiki is running${NC}"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "  Dashboard:  ${CYAN}http://localhost:5174${NC}"
  echo -e "  API:        ${CYAN}http://localhost:3900${NC}"
  echo -e "  WebSocket:  ${CYAN}ws://localhost:3900/ws${NC}"
  echo -e "  Health:     ${CYAN}http://localhost:3900/health${NC}"
  echo -e "  PostgreSQL: ${DIM}localhost:5433${NC}"
  echo -e "  Ollama:     ${DIM}localhost:11435${NC}"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# ── Stop ───────────────────────────────────────────────────────────

do_stop() {
  echo -e "${YELLOW}Shutting down Shiki...${NC}"

  # Stop Deno backend
  if [ -f "$PID_DIR/backend.pid" ]; then
    PID=$(cat "$PID_DIR/backend.pid")
    if kill -0 "$PID" 2>/dev/null; then
      echo -e "  Stopping backend (PID $PID)..."
      kill "$PID" 2>/dev/null || true
    fi
    rm -f "$PID_DIR/backend.pid"
  fi

  # Stop Vite frontend
  if [ -f "$PID_DIR/frontend.pid" ]; then
    PID=$(cat "$PID_DIR/frontend.pid")
    if kill -0 "$PID" 2>/dev/null; then
      echo -e "  Stopping frontend (PID $PID)..."
      kill "$PID" 2>/dev/null || true
    fi
    rm -f "$PID_DIR/frontend.pid"
  fi

  # Stop Docker services
  if docker compose ps --quiet 2>/dev/null | grep -q .; then
    echo -e "  Stopping Docker services..."
    docker compose down
  fi

  echo -e "${GREEN}Shiki stopped.${NC}"
}

# ── Status ─────────────────────────────────────────────────────────

do_status() {
  echo -e "${GREEN}四季 Shiki — Status${NC}"
  echo ""

  if ! is_initialized; then
    echo -e "${YELLOW}Not initialized.${NC} Run: ${BOLD}./shiki init${NC}"
    echo ""
    return
  fi

  # Docker
  echo -e "${CYAN}Docker services:${NC}"
  if docker compose ps 2>/dev/null | grep -q "running"; then
    docker compose ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null
  else
    echo -e "  ${DIM}not running${NC}"
  fi
  echo ""

  # Backend
  echo -ne "${CYAN}Backend (port 3900):${NC} "
  if is_running backend; then
    echo -e "${GREEN}running${NC} (PID $(cat "$PID_DIR/backend.pid"))"
    if curl -sf http://localhost:3900/health &>/dev/null; then
      echo -e "  ${GREEN}✓${NC} Health check passed"
    fi
  else
    echo -e "${DIM}not running${NC}"
  fi

  # Frontend
  echo -ne "${CYAN}Frontend (port 5174):${NC} "
  if is_running frontend; then
    echo -e "${GREEN}running${NC} (PID $(cat "$PID_DIR/frontend.pid"))"
  else
    echo -e "${DIM}not running${NC}"
  fi

  # Projects
  echo ""
  echo -e "${CYAN}Projects:${NC}"
  if [ -d "projects" ]; then
    local count=0
    for dir in projects/*/; do
      if [ -d "$dir" ] && [ "$(basename "$dir")" != "*" ]; then
        local proj_name=$(basename "$dir")
        local branch=""
        if [ -d "$dir/.git" ]; then
          branch=$(cd "$dir" && git branch --show-current 2>/dev/null)
          branch=" ${DIM}($branch)${NC}"
        fi
        echo -e "  ${GREEN}$proj_name${NC}$branch"
        count=$((count + 1))
      fi
    done
    [ $count -eq 0 ] && echo -e "  ${DIM}none — run: ./shiki new <name>${NC}"
  else
    echo -e "  ${DIM}none — run: ./shiki new <name>${NC}"
  fi

  # Worktrees
  local worktree_count=$(git worktree list 2>/dev/null | wc -l | tr -d ' ')
  if [ "$worktree_count" -gt 1 ]; then
    echo ""
    echo -e "${CYAN}Active worktrees:${NC}"
    git worktree list 2>/dev/null | tail -n +2 | while read -r line; do
      echo -e "  ${DIM}$line${NC}"
    done
  fi

  echo ""
}

# ── Main ───────────────────────────────────────────────────────────

case "${1:-}" in
  init)       do_init ;;
  new)        do_new "$2" ;;
  start)      do_start ;;
  stop)       do_stop ;;
  status)     do_status ;;
  -h|--help)  do_help ;;
  "")
    # No args: show status if initialized, otherwise guide to init
    if is_initialized; then
      do_status
    else
      echo -e "${GREEN}四季 Shiki — Dev OS Workspace${NC}"
      echo ""
      echo -e "Welcome! Run ${BOLD}./shiki init${NC} to get started."
      echo ""
      do_help
    fi
    ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    echo ""
    do_help
    exit 1
    ;;
esac
