# Garage S3 — Local Development Secrets
# Copy to .env and edit: cp deploy/example.env deploy/.env
#
# These values override the dummy defaults in garage.toml at runtime
# via docker-compose environment + Garage CLI flags.

GARAGE_RPC_SECRET=replace-me-with-64-hex-chars-generate-with-openssl-rand-hex-32
GARAGE_ADMIN_TOKEN=replace-me-with-admin-token
GARAGE_METRICS_TOKEN=replace-me-with-metrics-token
