#!/usr/bin/env bash
# shiki — Main entry point for the Shiki orchestrator system
#
# Usage:
#   shiki start     Full cold start: docker + seed (if needed) + board + agents
#   shiki stop      Kill all sessions and stop containers
#   shiki status    Quick orchestrator status
#   shiki attach    Attach to running session
#   shiki decide    Answer pending decisions
#   shiki report    Daily digest
#
# From scratch (first time ever):
#   shiki start
#
# Daily use (containers already running):
#   shiki start

set -euo pipefail

SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || python3 -c "import os; print(os.path.realpath('$0'))")"
WORKSPACE="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
SCRIPTS="$WORKSPACE/scripts"
SHIKI_CTL="$WORKSPACE/tools/shiki-ctl/.build/debug/shiki-ctl"
SESSION="shiki-board"

GREEN='\033[32m'
DIM='\033[2m'
YELLOW='\033[33m'
RED='\033[31m'
RST='\033[0m'

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in

  start)
    echo -e "${GREEN}Starting Shiki system...${RST}"
    echo

    # Step 1: Ensure Docker containers are running
    echo -e "${YELLOW}[1/4] Docker containers${RST}"
    if curl -sf http://localhost:3900/health >/dev/null 2>&1; then
      echo -e "  ${DIM}Backend already running${RST}"
    else
      echo "  Starting containers..."
      (cd "$WORKSPACE" && docker compose up -d 2>&1 | sed 's/^/  /')
      echo "  Waiting for backend..."
      for i in $(seq 1 30); do
        if curl -sf http://localhost:3900/health >/dev/null 2>&1; then break; fi
        sleep 1
      done
      if ! curl -sf http://localhost:3900/health >/dev/null 2>&1; then
        echo -e "  ${RED}Backend failed to start${RST}"
        exit 1
      fi
      echo -e "  ${GREEN}Backend ready${RST}"
    fi

    # Step 2: Check if companies exist, seed if not
    echo -e "${YELLOW}[2/4] Orchestrator data${RST}"
    COMPANY_COUNT=$(curl -sf http://localhost:3900/api/companies | python3 -c "import json,sys; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")
    if [ "$COMPANY_COUNT" -gt 0 ]; then
      echo -e "  ${DIM}$COMPANY_COUNT companies found${RST}"
    else
      echo "  No companies found — seeding..."
      bash "$SCRIPTS/seed-companies.sh" 2>&1 | sed 's/^/  /'
    fi

    # Step 3: Build shiki-ctl if needed
    echo -e "${YELLOW}[3/4] shiki-ctl${RST}"
    if [ -f "$SHIKI_CTL" ]; then
      echo -e "  ${DIM}Already built${RST}"
    else
      echo "  Building..."
      (cd "$WORKSPACE/tools/shiki-ctl" && swift build 2>&1 | tail -3 | sed 's/^/  /')
    fi

    # Step 4: Launch tmux layout + agents
    echo -e "${YELLOW}[4/4] Launching board${RST}"
    bash "$SCRIPTS/orchestrate.sh"
    ;;

  stop)
    echo -e "${YELLOW}Stopping Shiki system...${RST}"
    if tmux has-session -t "$SESSION" 2>/dev/null; then
      tmux kill-session -t "$SESSION"
      echo "  Killed tmux session"
    fi
    echo -e "${DIM}Containers left running (use 'docker compose down' to stop)${RST}"
    ;;

  status)
    if [ -f "$SHIKI_CTL" ]; then
      "$SHIKI_CTL" status
    else
      echo "shiki-ctl not built. Run: shiki start"
      exit 1
    fi
    ;;

  attach)
    if tmux has-session -t "$SESSION" 2>/dev/null; then
      tmux attach-session -t "$SESSION"
    else
      echo "No session running. Run: shiki start"
      exit 1
    fi
    ;;

  board)
    if [ -f "$SHIKI_CTL" ]; then
      "$SHIKI_CTL" board "$@"
    else
      echo "shiki-ctl not built. Run: shiki start"
      exit 1
    fi
    ;;

  history)
    if [ -f "$SHIKI_CTL" ]; then
      "$SHIKI_CTL" history "$@"
    else
      echo "shiki-ctl not built. Run: shiki start"
      exit 1
    fi
    ;;

  decide)
    if [ -f "$SHIKI_CTL" ]; then
      "$SHIKI_CTL" decide
    else
      echo "shiki-ctl not built. Run: shiki start"
      exit 1
    fi
    ;;

  report)
    if [ -f "$SHIKI_CTL" ]; then
      "$SHIKI_CTL" report "$@"
    else
      echo "shiki-ctl not built. Run: shiki start"
      exit 1
    fi
    ;;

  help|*)
    echo "Usage: shiki <command>"
    echo
    echo "Commands:"
    echo "  start     Launch everything (docker + seed + board + dispatcher)"
    echo "  stop      Kill tmux session"
    echo "  status    Orchestrator status overview (active/queued/idle)"
    echo "  board     Rich board: tasks, budget, health, last session per company"
    echo "  history   Session transcript history (shiki history maya)"
    echo "  attach    Attach to running session"
    echo "  decide    Answer pending decisions"
    echo "  report    Daily cross-company digest"
    ;;

esac
